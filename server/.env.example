PORT=3000

# PostgreSQL
NEXT_PUBLIC_SUPABASE_URL=postgresql://msw:msw_pass@localhost:5432/minesweeper

# Redis (optional — presence features degrade gracefully if absent)
REDIS_URL=redis://localhost:6379

# JWT — change this to a long random string in production
SUPABASE_JWT_SECRET=change_me_in_production_use_openssl_rand_hex_32

# CORS origin (set to your frontend domain in production)
CORS_ORIGIN=http://localhost:3000